{
  "name": "rawabet-frontend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:android": "vite build --mode android",
    "android:init": "npm run build:android && cap add android",
    "android:sync": "npm run build:android && cap sync android",
    "android:apk": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  }
}
